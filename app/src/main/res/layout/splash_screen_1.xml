<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_pattern">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:weightSum="100"
        android:gravity="center_horizontal">

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="15" />

        <ImageView
            android:id="@+id/logoIcon"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="35"
            android:contentDescription="@string/icon_image_description"
            app:srcCompat="@drawable/cubing_robot_logo_icon" />

        <TextView
            android:id="@+id/appName"
            style="@style/WindowTitleText"
            android:layout_weight="20"
            android:text="@string/app_name" />

        <ProgressBar
            android:id="@+id/appLoadingProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="10"
            android:layout_margin="20dp"/>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="10" />

        <TextView
            android:id="@+id/initialization_step_message"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="10"
            android:textSize="18sp"
            android:textColor="@color/light_grey"
            android:text=""/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>